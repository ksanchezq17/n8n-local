### Copy to `.env` and adjust as needed
#
# Windows note: if you're using Docker Desktop + WSL2 with an NVIDIA GPU,
# ensure your Docker engine can see the GPU (NVIDIA drivers + WSL2 GPU support).

## n8n
N8N_PORT=5678
# Set this to a real secret in docker/.env
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# If you want to access n8n from other devices on your LAN, set to your machine IP or a DNS name.
N8N_HOST=localhost
# Example: http://localhost:5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678

## LLM - Ollama (AMD GPU via ROCm)
OLLAMA_PORT=11434
# Optional; example values sometimes used: 11.0.0 (only if your ROCm stack needs it)
OLLAMA_HSA_OVERRIDE_GFX_VERSION=

## LLM - vLLM (GPU, OpenAI-compatible)
VLLM_PORT=8000
# Example HF model. Replace with what you plan to run.
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Common values: float16, bfloat16, auto
VLLM_DTYPE=auto

